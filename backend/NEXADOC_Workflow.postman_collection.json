          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{responsable_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"justification\": \"Dossier complexe nécessitant un avis administratif\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/deposit-requests/{{deposit_request_id}}/second-review",
              "host": ["{{base_url}}"],
              "path": ["deposit-requests", "{{deposit_request_id}}", "second-review"]
            }
          }
        },
        {
          "name": "Approuver (Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"justification\": \"Validation finale approuvée\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/deposit-requests/{{deposit_request_id}}/approve",
              "host": ["{{base_url}}"],
              "path": ["deposit-requests", "{{deposit_request_id}}", "approve"]
            }
          }
        },
        {
          "name": "Publier (Bibliothécaire)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bibliothecaire_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/deposit-requests/{{deposit_request_id}}/publish",
              "host": ["{{base_url}}"],
              "path": ["deposit-requests", "{{deposit_request_id}}", "publish"]
            }
          }
        }
