            "body": {
              "mode": "raw",
              "raw": "{\n    \"manager_id\": 5\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/deposit-requests/{{deposit_request_id}}/assign",
              "host": ["{{base_url}}"],
              "path": ["deposit-requests", "{{deposit_request_id}}", "assign"]
