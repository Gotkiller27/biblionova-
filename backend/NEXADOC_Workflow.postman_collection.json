                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/deposit-requests/{{deposit_request_id}}/reject",
              "host": ["{{base_url}}"],
              "path": ["deposit-requests", "{{deposit_request_id}}", "reject"]
            }
          }
        },
        {
